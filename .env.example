# Backend API（连接真实后端时使用）
NEXT_PUBLIC_API_URL=http://localhost:8001
NEXT_PUBLIC_API_PREFIX=/api/v1

# ── Mock API 模式 ──
# 设为 true 后，前端使用 Mock Service Worker 拦截所有请求，无需后端即可运行。
# 内置 20 用户 + 50 帖子 + 评论 + 打分，可浏览/登录/发帖/评论。
# 登录凭据：任意种子用户的手机号 + 密码 Test1234!（或短信登录任意手机号）
# 管理员账号：admin_ids 见下方 ADMIN_USER_IDS
NEXT_PUBLIC_MOCK_API=true

# JWT 密钥（mock 模式下需与 middleware 共用，用于签发/验证 token）
# 连接真实后端时，需与后端的 JWT_SECRET_KEY 保持一致
JWT_SECRET_KEY=xTrue-mock-demo-key-2026

# 管理后台 /xtrue-admin（middleware 白名单）
# 逗号分隔的 user_id。mock 模式内置管理员：1001、1002
# 连接真实后端时，跑完 backend/scripts/seed_plan_0502.py 后按控制台打印填写
ADMIN_USER_IDS=1001,1002
